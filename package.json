{
  "name": "@gitlab/svgs",
  "version": "3.137.0",
  "description": "SVG Assets for GitLab",
  "main": "./index.js",
  "repository": "git@gitlab.com:gitlab-org/gitlab-svgs.git",
  "author": "GitLab",
  "private": false,
  "license": "MIT",
  "scripts": {
    "svg": "build_scripts/build-svgs.sh",
    "dev": "yarn run svg && nuxt",
    "build": "nuxt build",
    "start": "nuxt start",
    "generate": "nuxt generate",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore ."
  },
  "devDependencies": {
    "@arkweid/lefthook": "^0.7.7",
    "@gitlab/eslint-plugin": "21.1.0",
    "@gitlab/svgs": "^3.137.0",
    "@gitlab/ui": "^115.0.0",
    "@nuxtjs/tailwindcss": "6.11.4",
    "dompurify": "^3.2.4",
    "eslint": "8.57.1",
    "glob": "^7.1.3",
    "mkdirp": "^0.5.1",
    "nuxt": "^2.18.1",
    "pikaday": "1.8.0",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "rimraf": "^2.6.2",
    "sass": "^1.85.1",
    "sass-loader": "^10.5.2",
    "svg-sprite": "^1.5.0",
    "svgo": "^1.3.0"
  },
  "resolutions": {
    "chokidar": "3.6.0",
    "sass-loader": "^10.5.2",
    "vue": "2.7.16",
    "vue-server-renderer": "2.7.16"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/exec",
        {
          "analyzeCommitsCmd": "./build_scripts/analyze-commits.sh ${lastRelease.gitTag}",
          "generateNotesCmd": "./build_scripts/generate-notes.sh ${lastRelease.gitTag} ${nextRelease.version}"
        }
      ],
      "@semantic-release/npm",
      "@semantic-release/git",
      "@semantic-release/gitlab"
    ],
    "success": false,
    "fail": false
  }
}
