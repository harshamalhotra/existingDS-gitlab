{
  "name": "@gitlab/svgs",
  "version": "3.149.0",
  "description": "SVG Assets for GitLab",
  "main": "./index.js",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/gitlab-org/gitlab-services/design.gitlab.com.git",
    "directory": "packages/gitlab-svgs"
  },
  "author": "GitLab",
  "private": false,
  "license": "MIT",
  "files": [
    "dist",
    "src",
    "index.js"
  ],
  "scripts": {
    "svg": "make svgs",
    "dev": "nuxt",
    "build": "nuxt build",
    "start": "nuxt start",
    "prepare": "yarn run svg",
    "generate": "nuxt generate"
  },
  "devDependencies": {
    "@gitlab/svgs": "*",
    "@gitlab/ui": "*",
    "@nuxtjs/tailwindcss": "6.14.0",
    "dompurify": "^3.2.4",
    "glob": "^7.2.3",
    "mkdirp": "^0.5.1",
    "nuxt": "^2.18.1",
    "pikaday": "1.8.0",
    "rimraf": "^2.6.2",
    "sass": "^1.85.1",
    "sass-loader": "^10.5.2",
    "svg-sprite": "^1.5.0",
    "svgo": "^1.3.0"
  },
  "resolutions": {
    "chokidar": "3.6.0",
    "sass-loader": "^10.5.2",
    "vue": "2.7.16",
    "vue-server-renderer": "2.7.16"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/exec",
        {
          "analyzeCommitsCmd": "./build_scripts/analyze-commits.sh ${lastRelease.gitTag}",
          "generateNotesCmd": "./build_scripts/generate-notes.sh ${lastRelease.gitTag} ${nextRelease.version}"
        }
      ],
      "@semantic-release/npm",
      "@semantic-release/git",
      "@semantic-release/gitlab"
    ],
    "success": false,
    "fail": false
  }
}
