{
  "font": {
    "size": {
      "base": {
        "$value": "{font.size.md}",
        "$type": "dimension",
        "$extensions": {
          "com.figma.scope": [
            "FONT_SIZE"
          ]
        }
      }
    },
    "weight": {
      "heading": {
        "$value": "{font.weight.bold}",
        "$type": "fontWeight",
        "$extensions": {
          "com.figma.scope": [
            "FONT_WEIGHT"
          ]
        }
      }
    }
  }
}
