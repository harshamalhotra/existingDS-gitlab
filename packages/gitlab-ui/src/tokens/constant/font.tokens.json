{
  "font": {
    "family": {
      "regular": {
        "$value": "var(--default-regular-font, 'GitLab Sans'), -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Noto Sans', Ubuntu, Cantarell, 'Helvetica Neue', sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji'",
        "$type": "fontFamily",
        "$extensions": {
          "com.figma.scope": []
        }
      },
      "monospace": {
        "$value": "var(--default-mono-font, 'GitLab Mono'), 'JetBrains Mono', 'Menlo', 'DejaVu Sans Mono', 'Liberation Mono', 'Consolas', 'Ubuntu Mono', 'Courier New', 'andale mono', 'lucida console', monospace",
        "$type": "fontFamily",
        "$extensions": {
          "com.figma.scope": []
        }
      }
    },
    "size": {
      "xs": {
        "$value": "0.625rem",
        "$type": "dimension",
        "$extensions": {
          "com.figma.scope": []
        }
      },
      "sm": {
        "$value": "0.75rem",
        "$type": "dimension",
        "$extensions": {
          "com.figma.scope": []
        }
      },
      "md": {
        "$value": "0.875rem",
        "$type": "dimension",
        "$extensions": {
          "com.figma.scope": []
        }
      },
      "lg": {
        "$value": "1rem",
        "$type": "dimension",
        "$extensions": {
          "com.figma.scope": []
        }
      }
    },
    "weight": {
      "100": {
        "$value": "100",
        "$type": "fontWeight",
        "$extensions": {
          "com.figma.scope": []
        }
      },
      "300": {
        "$value": "300",
        "$type": "fontWeight",
        "$extensions": {
          "com.figma.scope": []
        }
      },
      "normal": {
        "$value": "400",
        "$type": "fontWeight",
        "$extensions": {
          "com.figma.scope": []
        }
      },
      "semibold": {
        "$value": "500",
        "$type": "fontWeight",
        "$extensions": {
          "com.figma.scope": []
        }
      },
      "bold": {
        "$value": "600",
        "$type": "fontWeight",
        "$extensions": {
          "com.figma.scope": []
        }
      }
    }
  }
}
